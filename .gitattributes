# Ensure consistent line endings across platforms
* text=auto

# Python files should always use LF
*.py text eol=lf

# JavaScript/TypeScript files should always use LF  
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Configuration files should use LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Shell scripts should use LF
*.sh text eol=lf

# Markdown files should use LF
*.md text eol=lf

# Keep Windows batch files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf 